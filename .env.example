# ─── LLM & Embedding ──────────────────────────────────────────────
# GROQ: Get key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional: ANTHROPIC or OPENAI
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ─── Reranking ────────────────────────────────────────────────────
# COHERE: Get key at https://dashboard.cohere.com/ (free trial available)
COHERE_API_KEY=your_cohere_api_key_here

# ─── Database ─────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword

# ─── Vector Store ─────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_documents

# ─── Cache ────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CACHE_TTL=3600

# ─── App Settings ─────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=generate_a_random_string_for_production
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── RAG Tuning ───────────────────────────────────────────────────
# EMBEDDING: Use "all-MiniLM-L6-v2" (384d) for local Hugging Face (default).
# Use "text-embedding-3-small" (1536d) for OpenAI.
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# LLM: "llama3-70b-8192" or "mixtral-8x7b-32768" for Groq.
# "gpt-4o" for OpenAI, "claude-3-5-sonnet-20240620" for Anthropic.
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=2048

CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
